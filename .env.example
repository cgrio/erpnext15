# ============================================
# ERPNext + WooCommerce Configuration
# ============================================
# Copie este arquivo para .env e ajuste conforme necessário
# No Portainer, defina estas variáveis no Stack UI

# Database Configuration
MYSQL_ROOT_PASSWORD=ErpN3xt#2026

# Redis Configuration
REDIS_PASSWORD=redis#2026

# Frappe Site Configuration
FRAPPE_SITE_NAME=erpnext.local
ADMIN_PASSWORD=admin@123

# Network & Proxy Configuration (Cloudflare)
# Use o seu domínio público ou IP do tunnel aqui
HTTP_HOST=localhost
HTTP_PORT=8090

# Proxy Headers - Ajuste conforme seu reverse proxy
# Para Cloudflare Tunnel, use:
UPSTREAM_REAL_IP_ADDRESS=0.0.0.0/0
UPSTREAM_REAL_IP_HEADER=CF-Connecting-IP
UPSTREAM_REAL_IP_RECURSIVE=on

# Performance Tuning
WORKERS=4
THREADS=4
TIMEOUT=120

# ============================================
# INSTRUÇÕES PARA PORTAINER
# ============================================
# 1. Crie um stack novo no Portainer
# 2. Cole o conteúdo do docker-compose.yml
# 3. Na seção "Environment variables", adicione:
#    - MYSQL_ROOT_PASSWORD
#    - REDIS_PASSWORD
#    - FRAPPE_SITE_NAME
#    - ADMIN_PASSWORD
#    - HTTP_HOST (seu domínio)
# 4. Deploy
# 5. Aguarde ~2 minutos para o site ser criado
# 6. Acesse http://[seu-host]:8090
#
# Default credentials (MUDE IMEDIATAMENTE):
# Username: Administrator
# Password: (valor de ADMIN_PASSWORD)
# ============================================
